<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>StockAnalyzer — @ViewData["Title"]</title>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body { font-family: 'Segoe UI', system-ui, sans-serif; background: #0f1117; color: #e2e8f0; min-height: 100vh; }
        header { background: #1a1d27; border-bottom: 1px solid #2d3748; padding: 1rem 2rem; display: flex; align-items: center; gap: 1rem; }
        header h1 { font-size: 1.25rem; font-weight: 600; color: #63b3ed; }
        main { padding: 2rem; max-width: 1400px; margin: 0 auto; }
        .badge { display: inline-block; padding: 0.2rem 0.6rem; border-radius: 9999px; font-size: 0.75rem; font-weight: 600; }
        .badge-comprar { background: #22543d; color: #68d391; }
        .badge-vender  { background: #742a2a; color: #fc8181; }
        .badge-mantener { background: #2d3748; color: #a0aec0; }
        .badge-alta { background: #2a4365; color: #63b3ed; }
        .badge-media { background: #2d3748; color: #a0aec0; }
        table { width: 100%; border-collapse: collapse; }
        th { text-align: left; padding: 0.75rem 1rem; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; color: #718096; border-bottom: 1px solid #2d3748; }
        td { padding: 0.75rem 1rem; border-bottom: 1px solid #1a1d27; font-size: 0.875rem; }
        tr:hover td { background: #1a1d27; }
        .card { background: #1a1d27; border: 1px solid #2d3748; border-radius: 0.5rem; padding: 1.25rem; }
        .cards-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 1rem; margin-bottom: 2rem; }
        .card h3 { font-size: 1rem; font-weight: 600; margin-bottom: 0.75rem; color: #63b3ed; }
        .card-stat { font-size: 0.8rem; color: #718096; margin-top: 0.25rem; }
        .trend-icons { margin-top: 0.5rem; font-size: 1.1rem; letter-spacing: 0.1rem; }
        .filter-bar { display: flex; gap: 1rem; margin-bottom: 1.5rem; align-items: flex-end; flex-wrap: wrap; }
        .filter-bar label { font-size: 0.75rem; color: #718096; display: block; margin-bottom: 0.25rem; }
        .filter-bar select, .filter-bar button { background: #1a1d27; border: 1px solid #2d3748; color: #e2e8f0; padding: 0.5rem 0.75rem; border-radius: 0.375rem; font-size: 0.875rem; }
        .filter-bar button { background: #2b6cb0; border-color: #2b6cb0; cursor: pointer; }
        .filter-bar button:hover { background: #3182ce; }
        .empty-msg { text-align: center; padding: 3rem; color: #718096; font-size: 0.9rem; }
        .table-wrap { background: #1a1d27; border: 1px solid #2d3748; border-radius: 0.5rem; overflow: hidden; }
    </style>
</head>
<body>
    <header>
        <span style="font-size:1.5rem;">📈</span>
        <h1>StockAnalyzer Dashboard</h1>
    </header>
    <main>
        @RenderBody()
    </main>
</body>
</html>
